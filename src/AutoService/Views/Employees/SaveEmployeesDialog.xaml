<Window x:Class="AutoService.Views.Employees.SaveEmployeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:AutoService.Views.Behaviors"
        Title="Новый сотрудник" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="RequiredTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#FF707070"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3,24,3"/>
            <Setter Property="Validation.ErrorTemplate">
                <Setter.Value>
                    <ControlTemplate>
                        <Grid>
                            <Border BorderBrush="Red" 
                                    BorderThickness="1" 
                                    CornerRadius="1">
                                <AdornedElementPlaceholder x:Name="placeholder"/>
                            </Border>
                            <TextBlock Text="⚠" 
                                       Foreground="Red" 
                                       FontSize="14"
                                       Margin="0,0,6,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- Фамилия (обязательная) -->
        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
            <Run Text="Фамилия"/><Run Text="*" Foreground="Red"/><Run Text=":"/>
        </TextBlock>
        <TextBox x:Name="LastNameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" 
                 Style="{StaticResource RequiredTextBoxStyle}"
                 Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <!-- Имя (обязательное) -->
        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
            <Run Text="Имя"/><Run Text="*" Foreground="Red"/><Run Text=":"/>
        </TextBlock>
        <TextBox x:Name="FirstNameTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" 
                 Style="{StaticResource RequiredTextBoxStyle}"
                 Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <!-- Отчество (НЕ обязательное) -->
        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" Text="Отчество:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" 
                 Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Телефон (обязательный) -->
        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
            <Run Text="Телефон"/><Run Text="*" Foreground="Red"/><Run Text=":"/>
        </TextBlock>
        <TextBox x:Name="PhoneTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" 
                 Style="{StaticResource RequiredTextBoxStyle}"
                 Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 behaviors:PhoneMaskBehavior.UseMask="True"/>

        <!-- Комментарий (необязательный) -->
        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,8" Text="Комментарий:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" 
                 Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" TextWrapping="Wrap" Height="60"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="OkButton" Width="90" Margin="0,0,8,0" IsDefault="True" Content="OK" Click="Ok_Click"/>
            <Button Width="90" IsCancel="True" Content="Отмена"/>
        </StackPanel>
    </Grid>
</Window>