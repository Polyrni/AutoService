<Window x:Class="AutoService.Views.Services.SaveServiceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая услуга" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="RequiredTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#FF707070"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3,24,3"/>
            <Setter Property="Validation.ErrorTemplate">
                <Setter.Value>
                    <ControlTemplate>
                        <Grid>
                            <Border BorderBrush="Red" BorderThickness="1" CornerRadius="1">
                                <AdornedElementPlaceholder x:Name="placeholder"/>
                            </Border>
                            <TextBlock Text="⚠" Foreground="Red" FontSize="14"
                                       Margin="0,0,6,0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- Специализация (обязательная) - Row 0 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
            <Run Text="Специализация"/><Run Text="*" Foreground="Red"/><Run Text=":"/>
        </TextBlock>
        <TextBox x:Name="SpecializationTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" 
                 Style="{StaticResource RequiredTextBoxStyle}"
                 Text="{Binding Specialization, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <!-- Вид работы (обязательное) - Row 1 -->
        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
            <Run Text="Вид работы"/><Run Text="*" Foreground="Red"/><Run Text=":"/>
        </TextBlock>
        <TextBox x:Name="NameTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" 
                 Style="{StaticResource RequiredTextBoxStyle}"
                 Text="{Binding ServiceName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <!-- Стоимость (обязательная) - Row 2 -->
        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">
            <Run Text="Стоимость"/><Run Text="*" Foreground="Red"/><Run Text=":"/>
        </TextBlock>
        <TextBox x:Name="CostTextBox"
                 Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"
                 Style="{StaticResource RequiredTextBoxStyle}"
                 PreviewTextInput="CostTextBox_PreviewTextInput"
                 Text="{Binding CostText, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <!-- Кнопки - Row 3 -->
        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="OkButton" Width="90" Margin="0,0,8,0" IsDefault="True" Content="OK" Click="Ok_Click"/>
            <Button Width="90" IsCancel="True" Content="Отмена"/>
        </StackPanel>
    </Grid>
</Window>