
    <Window x:Class="AutoService.Views.Orders.SaveOrderDialog"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            Title="Заказ" Height="600" Width="700"
            WindowStartupLocation="CenterOwner"
            ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="SearchableComboBoxStyle" TargetType="ComboBox">
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="StaysOpenOnEdit" Value="True"/>
            <Setter Property="IsTextSearchEnabled" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="PART_EditableTextBox"
                                 Grid.Column="0"
                                 Padding="2"
                                 Text="{Binding Path=Tag, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center"
                                 Background="White"/>

                            <ToggleButton Grid.Column="1"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      ClickMode="Press">
                                <Path HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                  Fill="Black"/>
                            </ToggleButton>

                            <Popup Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                                <Border Margin="0,2,0,0"
                                    Background="White"
                                    BorderBrush="Gray"
                                    BorderThickness="1">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Номер заказа -->
        <Label Grid.Row="0" Grid.Column="0" Content="Номер заказа:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1"
                 Text="{Binding OrderNumber}"
                 IsReadOnly="True"
                 Background="LightGray"
                 Margin="5"/>

        <!-- Клиент -->
        <Label Grid.Row="1" Grid.Column="0"
               Content="Клиент:"
               VerticalAlignment="Center"/>

        <ComboBox x:Name="CustomerComboBox"
                  Grid.Row="1" Grid.Column="1"
                  Margin="5"
                  Style="{StaticResource SearchableComboBoxStyle}"
                  ItemsSource="{Binding CustomersView}"
                  SelectedItem="{Binding SelectedCustomer}"
                  HorizontalAlignment="Stretch"
                  Tag="{Binding CustomerFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding LastName}" Margin="2,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding FirstName}" Margin="2,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding MiddleName}" Margin="2,0"/>
                    </Grid>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- Услуги -->
        <Label Grid.Row="2" Grid.Column="0" Content="Услуги:" VerticalAlignment="Top" Margin="0,5,0,0"/>
        <Grid Grid.Row="2" Grid.Column="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                <ComboBox Style="{StaticResource SearchableComboBoxStyle}"
                          ItemsSource="{Binding ServicesView}"
                          SelectedItem="{Binding SelectedService}"
                          Width="250"
                          Margin="0,0,5,0"
                          Tag="{Binding ServiceFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" Margin="2,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Specialization}" Margin="2,0"
                                           Foreground="Gray"/>
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="Добавить услугу"
                        Command="{Binding AddServiceCommand}"
                        Padding="10,2"/>
            </StackPanel>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding SelectedServices}"
                      SelectedItem="{Binding SelectedOrderService}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Специализация"
                                        Binding="{Binding Service.Specialization}"
                                        Width="*"
                                        IsReadOnly="True"/>
                    <DataGridTextColumn Header="Вид работы"
                                        Binding="{Binding Service.Name}"
                                        Width="*"
                                        IsReadOnly="True"/>
                    <DataGridTextColumn Header="Цена"
                                        Binding="{Binding Price}"
                                        Width="100"/>
                    <DataGridTemplateColumn Header="Действия"
                                            Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Удалить"
                                        Command="{Binding DataContext.RemoveServiceCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Сотрудники -->
        <Label Grid.Row="3" Grid.Column="0" Content="Сотрудники:" VerticalAlignment="Top" Margin="0,5,0,0"/>
        <Grid Grid.Row="3" Grid.Column="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                <ComboBox Style="{StaticResource SearchableComboBoxStyle}"
                          ItemsSource="{Binding EmployeesView}"
                          SelectedItem="{Binding SelectedEmployee}"
                          Width="250"
                          Margin="0,0,5,0"
                          Tag="{Binding EmployeeFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding LastName}" Margin="2,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding FirstName}" Margin="2,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding MiddleName}" Margin="2,0"/>
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="Добавить сотрудника"
                        Command="{Binding AddEmployeeCommand}"
                        Padding="10,2"/>
            </StackPanel>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding SelectedEmployees}"
                      SelectedItem="{Binding SelectedEmployeeForRemove}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Фамилия"
                                        Binding="{Binding LastName}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Имя"
                                        Binding="{Binding FirstName}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Отчество"
                                        Binding="{Binding MiddleName}"
                                        Width="*"/>
                    <DataGridTemplateColumn Header="Действия"
                                            Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Удалить"
                                        Command="{Binding DataContext.RemoveEmployeeCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Сумма -->
        <Label Grid.Row="4" Grid.Column="0" Content="Итого:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="1"
                 Text="{Binding TotalAmount, StringFormat={}{0:N2} ₽}"
                 IsReadOnly="True"
                 Background="LightGray"
                 Margin="5"/>

        <!-- Примечание -->
        <Label Grid.Row="5" Grid.Column="0" Content="Примечание:" VerticalAlignment="Top" Margin="0,5,0,0"/>
        <TextBox Grid.Row="5" Grid.Column="1"
                 Text="{Binding Note}"
                 Height="60"
                 TextWrapping="Wrap"
                 Margin="5"
                 AcceptsReturn="True"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="6"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="Сохранить"
                    Command="{Binding SaveCommand}"
                    Padding="20,5"
                    Margin="0,0,10,0"
                    IsDefault="True"/>
            <Button Content="Отмена"
                    Command="{Binding CancelCommand}"
                    Padding="20,5"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
